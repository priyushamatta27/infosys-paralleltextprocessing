from concurrent.futures import ThreadPoolExecutor

# Function that processes each chunk
def process_chunk(chunk):
    # Example processing: count words in the chunk
    word_count = sum(len(line.split()) for line in chunk)
    return word_count


def parallel_process(file_name, chunk_size=1000):

    results = []

    with open(file_name, "r", encoding="utf-8") as file:

        chunk = []

        with ThreadPoolExecutor() as executor:
            futures = []

            for line in file:
                chunk.append(line)

                if len(chunk) == chunk_size:
                    futures.append(executor.submit(process_chunk, chunk))
                    chunk = []

            # process remaining lines
            if chunk:
                futures.append(executor.submit(process_chunk, chunk))

            for future in futures:
                results.append(future.result())

    print("Total words:", sum(results))


if __name__ == "__main__":
    parallel_process("product_reviews_50000.csv", 2000)
