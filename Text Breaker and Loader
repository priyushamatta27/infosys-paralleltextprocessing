import re
import csv
from concurrent.futures import ThreadPoolExecutor


def split_into_sentences(text):
    """
    Split text into sentences using regex.
    """
    sentences = re.split(r'[.!?]', text)

    cleaned_sentences = []
    for sentence in sentences:
        sentence = sentence.strip()
        if sentence:
            cleaned_sentences.append(sentence)

    return cleaned_sentences


def process_chunk(chunk):
    """
    Process a chunk of text lines.
    """
    result = []

    for text in chunk:
        sentences = split_into_sentences(text)
        result.extend(sentences)

    return result


def chunk_data(data, chunk_size):
    """
    Divide dataset into chunks.
    """
    chunks = []

    for i in range(0, len(data), chunk_size):
        chunks.append(data[i:i + chunk_size])

    return chunks


def read_csv(file_path):
    """
    Read text from CSV file.
    """
    texts = []

    with open(file_path, 'r', encoding='utf-8') as file:
        reader = csv.reader(file)

        for row in reader:
            texts.append(row[0])

    return texts


def main():

    file_path = "product_reviews_50000.csv"

    print("Reading dataset...")
    texts = read_csv(file_path)

    print("Creating chunks...")
    chunks = chunk_data(texts, 1000)

    print("Starting parallel processing...")

    with ThreadPoolExecutor(max_workers=4) as executor:
        results = executor.map(process_chunk, chunks)

    final_sentences = []

    for chunk_result in results:
        final_sentences.extend(chunk_result)

    print("Total sentences extracted:", len(final_sentences))


if __name__ == "__main__":
    main()
