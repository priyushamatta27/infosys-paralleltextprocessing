import re
import csv
from concurrent.futures import ThreadPoolExecutor


def split_into_words(text):
    """Split text into words."""
    return re.findall(r'\b\w+\b', text)


def create_word_chunks(words, chunk_size=100):
    """Create chunks of words."""
    chunks = []
    for i in range(0, len(words), chunk_size):
        chunks.append(words[i:i + chunk_size])
    return chunks


def words_to_sentences(word_chunk):
    """Convert word chunk back to sentences."""
    text = " ".join(word_chunk)
    sentences = re.split(r'[.!?]', text)

    cleaned = []
    for s in sentences:
        s = s.strip()
        if s:
            cleaned.append(s)

    return cleaned


def process_chunk(chunk):
    """Process chunk in parallel."""
    return words_to_sentences(chunk)


def read_csv(file_path):
    """Read review text column from CSV."""
    texts = []

    with open(file_path, 'r', encoding='utf-8') as file:
        reader = csv.reader(file)

        next(reader)  # skip header

        for row in reader:
            if len(row) > 1:
                texts.append(row[1])  # read review text

    return texts


def main():

    file_path = "product_reviews_50000.csv"

    print("Reading dataset...")
    texts = read_csv(file_path)

    print("Breaking text into words...")

    all_words = []
    for text in texts:
        all_words.extend(split_into_words(text))

    print("\nTotal Words:", len(all_words))
    print("\nSample Words:")
    print(all_words[:20])

    print("\nCreating word chunks...")
    chunks = create_word_chunks(all_words, 200)

    print("Starting parallel processing...")

    final_sentences = []

    with ThreadPoolExecutor(max_workers=4) as executor:
        results = executor.map(process_chunk, chunks)

        for r in results:
            final_sentences.extend(r)

    print("\nSample Sentences:")
    for s in final_sentences[:10]:
        print(s)

    print("\nTotal sentences extracted:", len(final_sentences))


if __name__ == "__main__":
    main()
